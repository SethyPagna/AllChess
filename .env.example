NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEPLOYMENT_TARGET=local

# Supabase production or local project values. Never commit real secrets.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_DRIVER=supabase

# AI analysis. Values are read lazily by server routes only.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Cloudflare deployment. Use Wrangler secrets/resources, not committed values.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=allchess.example.com
DATABASE_DRIVER_CLOUDFLARE=d1
OBJECT_STORAGE_DRIVER=r2
R2_PUBLIC_BASE_URL=
HYPERDRIVE_ID=
D1_DATABASE_ID=

# Vercel CLI / CI. Set these as Vercel or GitHub secrets.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
