NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase production or local project values. Never commit real secrets.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# AI analysis. Values are read lazily by server routes only.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Vercel CLI / CI. Set these as Vercel or GitHub secrets.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
