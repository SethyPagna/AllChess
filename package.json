{
  "name": "allchess",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:stockfish": "node ops/scripts/assets/prepare-stockfish.ts",
    "dev": "npm run prepare:stockfish && next dev",
    "build": "npm run prepare:stockfish && next build --webpack",
    "start": "next start",
    "lint": "eslint . -c config/lint/eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config config/test/vitest.config.ts",
    "test:watch": "vitest --config config/test/vitest.config.ts",
    "test:i18n": "vitest run --config config/test/vitest.config.ts ops/tests/app/i18n.test.ts",
    "stop:local": "node ops/scripts/ops/maintenance/stop-local-node.ts",
    "clean:local": "node ops/scripts/ops/maintenance/clean-local-artifacts.ts",
    "clean:storage": "node ops/scripts/ops/maintenance/clean-local-artifacts.ts --git-gc",
    "test:e2e": "playwright test --config config/test/playwright.config.ts",
    "audit:env": "node ops/scripts/ops/audit/env-audit.ts",
    "audit:browser": "node ops/scripts/ops/audit/browser-validation.ts",
    "audit:live": "playwright test --config config/test/playwright.config.ts ops/tests/e2e/gameplay-audit.spec.ts",
    "bots:local-ai:check": "python ops/scripts/training/python/check_local_ai_readiness.py",
    "bots:train:data": "node ops/scripts/training/train-bot-knowledge.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "deploy:preview": "npm run verify && npx --yes vercel@latest deploy --name allchess",
    "deploy:prod": "npm run verify && npx --yes vercel@latest deploy --prod --name allchess",
    "cf:build": "npm run prepare:stockfish && next build --webpack && opennextjs-cloudflare build --skipNextBuild && node ops/scripts/ops/deploy/patch-opennext-worker.ts",
    "cf:preview": "npm run cf:build && wrangler dev --config ops/infra/cloudflare/wrangler.jsonc",
    "cf:cache:populate": "opennextjs-cloudflare populateCache remote --cacheChunkSize 1",
    "cf:deploy": "npm run cf:build && wrangler deploy .open-next/worker.js --config ops/infra/cloudflare/wrangler.jsonc --env=production",
    "cf:types": "wrangler types src/worker-configuration.d.ts --config ops/infra/cloudflare/wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply allchess --local --config ops/infra/cloudflare/wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply allchess --remote --config ops/infra/cloudflare/wrangler.jsonc",
    "db:catalog:sql": "node ops/scripts/data/sync-catalog-d1.ts --print",
    "db:catalog:sync:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ops/scripts/data/sync-catalog-d1.ps1 -Local",
    "db:catalog:sync:remote": "powershell -NoProfile -ExecutionPolicy Bypass -File ops/scripts/data/sync-catalog-d1.ps1 -Remote"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stockfish": "^18.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "@eslint/compat": "^2.1.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "router": {
      "path-to-regexp": "^8.4.2"
    }
  }
}
