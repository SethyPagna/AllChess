{
  "name": "allchess",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:stockfish": "node scripts/prepare-stockfish.mjs",
    "dev": "npm run prepare:stockfish && next dev",
    "build": "npm run prepare:stockfish && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:i18n": "vitest run tests/i18n.test.ts",
    "test:e2e": "playwright test",
    "audit:env": "node scripts/env-audit.mjs",
    "audit:live": "playwright test tests/e2e/gameplay-audit.spec.ts",
    "bots:train:data": "node scripts/train-bot-knowledge.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "deploy:preview": "npm run verify && vercel deploy --name allchess",
    "deploy:prod": "npm run verify && vercel deploy --prod --name allchess",
    "cf:build": "npm run prepare:stockfish && next build --webpack && opennextjs-cloudflare build --skipNextBuild && node scripts/patch-opennext-worker.mjs",
    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare populateCache remote --cacheChunkSize 1 && wrangler deploy --env=",
    "cf:types": "wrangler types src/worker-configuration.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply allchess --local",
    "db:migrate:remote": "wrangler d1 migrations apply allchess --remote"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.984.0",
    "@kaisukez/makruk-js": "^4.0.2",
    "chess.js": "^1.4.0",
    "chessops": "^0.15.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shogiops": "^0.21.0",
    "stockfish": "^18.0.7",
    "tailwind-merge": "^3.4.0",
    "xiangqiops": "^1.0.10",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@opennextjs/cloudflare": "^1.19.9",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vercel": "^53.4.0",
    "vitest": "^4.0.15",
    "wrangler": "^4.90.1"
  }
}
