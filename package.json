{
  "name": "allchess-multiplayer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:i18n": "vitest run tests/i18n.test.ts",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "deploy:preview": "npm run verify && vercel deploy",
    "deploy:prod": "npm run verify && vercel deploy --prod",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:start": "supabase start",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.87.1",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vercel": "^53.4.0",
    "vitest": "^4.0.15"
  }
}
