NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEPLOYMENT_TARGET=local
DATABASE_DRIVER=d1
OBJECT_STORAGE_DRIVER=r2
SESSION_SECRET=replace-with-random-session-secret

# AI analysis. Values are read lazily by server routes only.
# The adapter mirrors the Business OS provider pattern: Groq, Mistral,
# Cerebras, Google AI, and OpenAI are supported for coaching/review text.
AI_PROVIDER=openai
AI_MODEL=
AI_ENDPOINT_OVERRIDE=
AI_TIMEOUT_MS=
AI_MAX_COMPLETION_TOKENS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GROQ_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=

# Cloudflare deployment. Use Wrangler secrets/resources, not committed values.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=allchess.example.com
CLOUDFLARE_D1_DATABASE_ID=
R2_PUBLIC_BASE_URL=

# Google/Gmail OAuth is ready once these are configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Vercel CLI / CI. Set these as Vercel or GitHub secrets.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
